<?xml version="1.0" encoding="utf-8"?>
<!-- 
    Файл: App.xaml
    Описание: Глобальные ресурсы приложения.
    Правки: 
    - Удалена ссылка на Themes/Styles.xaml.
    - Добавлены цвета темы Coral Mint напрямую в Application.Resources.
-->
<Application
    x:Class="PortoPattern.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Converters="using:PortoPattern.Converters"
    xmlns:local="using:PortoPattern">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Controls/CardButtonStyle.xaml"/>
                <ResourceDictionary Source="ms-appx:///Controls/FolderCardStyle.xaml"/>
                <ResourceDictionary Source="ms-appx:///Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Глобальная палитра приложения (Coral Mint) -->
            <SolidColorBrush x:Key="App.Background" Color="#F97316"/>
            <SolidColorBrush x:Key="App.Surface" Color="#EA580C"/>
            <SolidColorBrush x:Key="App.Surface.Hover" Color="#FB923C"/>
            <SolidColorBrush x:Key="App.Border" Color="#FDBA74" Opacity="0.4"/>
            <SolidColorBrush x:Key="App.HeaderText" Color="#FFF7ED"/>
            <SolidColorBrush x:Key="App.TextPrimary" Color="#FFEDD5"/>
            <SolidColorBrush x:Key="App.TextSecondary" Color="#FED7AA"/>


            <!--#region [Fonts]-->
            <x:Double x:Key="FontSizeMedium">15</x:Double>
            <x:Double x:Key="FontSizeHuge">30</x:Double>
            <!--#endregion-->

            <Converters:BoolToVisibilityConverter x:Key="BooleanVisibility" />
            <Converters:BoolToVisibilityInverseConverter x:Key="BooleanVisibilityInverse" />
            <Converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <Converters:InverseNullToVisibilityConverter x:Key="InverseNullToVisibilityConverter"/>
            <Converters:AdminRequirementConverter x:Key="AdminRequirementConverter" />
            <Converters:BoolNegationConverter x:Key="BoolNegationConverter"/>
            <Converters:ConvertProfileName x:Key="ProfileNameConverter"/>
            <Converters:ConvertRuleToTooltip x:Key="RuleTooltipConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>