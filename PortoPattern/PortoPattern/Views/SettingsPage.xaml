<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PortoPattern.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:localControls="using:PortoPattern.Controls" 
    Background="#C4B5FD" 
    Opacity="0.5"
    mc:Ignorable="d">

    <StackPanel Padding="40" Spacing="15">
        <TextBlock Text="Настройки" Style="{ThemeResource TitleTextBlockStyle}"/>
        <TextBlock Text="{x:Bind ViewModel.Version, Mode=OneWay}" Foreground="Gray"/>

    </StackPanel>
</Page>