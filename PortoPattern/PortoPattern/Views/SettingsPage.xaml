<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PortoPattern.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:PortoPattern" 
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">


    <StackPanel Margin="20" Spacing="20" HorizontalAlignment="Center" VerticalAlignment="Center">

        <TextBlock Text="Пример использования ToolTipFade" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />

        <!-- Кнопка с тултипом с дефолтным FadeTime -->
        <Button Content="Кнопка с ToolTipFade (300ms)" Width="250" Height="50">
            <ToolTipService.ToolTip>
                <local:ToolTipFade FadeTime="300">
                    <Border Background="DarkSlateBlue" Padding="10" CornerRadius="5">
                        <TextBlock Foreground="White" Text="Это ToolTipFade с FadeTime = 300ms" />
                    </Border>
                </local:ToolTipFade>
            </ToolTipService.ToolTip>
        </Button>

        <!-- Кнопка с тултипом с медленным появлением -->
        <Button Content="Медленный ToolTipFade (1000ms)" Width="250" Height="50">
            <ToolTipService.ToolTip>
                <local:ToolTipFade FadeTime="1000">
                    <Border Background="DarkGreen" Padding="10" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Foreground="White" FontWeight="Bold" Text="Медленный FadeIn/FadeOut" />
                            <TextBlock Foreground="LightGreen" Text="FadeTime = 1000ms" />
                        </StackPanel>
                    </Border>
                </local:ToolTipFade>
            </ToolTipService.ToolTip>
        </Button>

        <!-- Кнопка с тултипом с быстрым появлением -->
        <Button Content="Быстрый ToolTipFade (150ms)" Width="250" Height="50">
            <ToolTipService.ToolTip>
                <local:ToolTipFade FadeTime="150">
                    <Border Background="DarkRed" Padding="10" CornerRadius="5">
                        <TextBlock Foreground="White" Text="Очень быстрый FadeTime = 150ms" />
                    </Border>
                </local:ToolTipFade>
            </ToolTipService.ToolTip>
        </Button>

        <!-- Кнопка с тултипом, где тултип содержит сложную разметку -->
        <Button Content="ToolTipFade со сложным содержимым" Width="250" Height="50">
            <ToolTipService.ToolTip>
                <local:ToolTipFade FadeTime="500">
                    <Border Background="#FF333333" Padding="15" CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="White" FontWeight="Bold" Text="Сложный тултип" FontSize="16"/>
                            <TextBlock Foreground="LightGray" Text="Вы можете добавить сюда любую разметку, картинки, кнопки и т.д." TextWrapping="Wrap" Margin="0,5,0,0" />
                            <Image Source="ms-appx:///Assets/Exclamation4.png" Width="40" Height="40" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </local:ToolTipFade>
            </ToolTipService.ToolTip>
        </Button>

        <!-- Пятый вариант — визитная карточка -->
        <Button Content="Визитная карточка ToolTipFade" Width="250" Height="50">
            <ToolTipService.ToolTip>
                <local:ToolTipFade FadeTime="600">
                    <Border 
                Background="#FF1E1E1E" 
                BorderBrush="#FF007AFF" 
                BorderThickness="2" 
                Padding="15" 
                CornerRadius="12"
                Width="280">
                        <StackPanel Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">

                            <!-- Иконка Apple -->
                            <Image 
                        Source="ms-appx:///Assets/Exclamation4.png" 
                        Width="60" 
                        Height="60"
                        Stretch="Uniform" />

                            <StackPanel VerticalAlignment="Center" Width="190">
                                <!-- Заголовок -->
                                <TextBlock 
                            Text="Apple Inc." 
                            Foreground="White" 
                            FontSize="20" 
                            FontWeight="Bold"
                            Margin="0,0,0,5"/>

                                <!-- Описание -->
                                <TextBlock 
                            Text="Инновационная компания, создающая технологии для будущего." 
                            Foreground="LightGray" 
                            TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </local:ToolTipFade>
            </ToolTipService.ToolTip>
        </Button>


    </StackPanel>

</Page>
