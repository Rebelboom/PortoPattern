<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PortoPattern.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PortoPattern.ViewModels"
    xmlns:controls="using:PortoPattern.Controls"
    Background="Transparent">

    <Grid Padding="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 
             Заголовок страницы:
             Foreground="{ThemeResource Porto.Text.Header}" - статический цвет заголовка (не меняется).
             FontSize="{StaticResource FontSizeHuge}" - размер с ключом 30.
        -->
        <StackPanel Spacing="8" Margin="0,0,0,40">
            <TextBlock Text="Домашняя страница" 
                       FontSize="{StaticResource FontSizeHuge}" 
                       FontWeight="Bold" 
                       Foreground="{ThemeResource Porto.Text.Header}"/>

            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                       FontSize="16" 
                       Foreground="{ThemeResource Porto.Text.Default}"
                       Opacity="0.8"/>

            <ProgressBar IsIndeterminate="True" 
                         Foreground="{ThemeResource Porto.Text.Default}"
                         Visibility="{x:Bind ViewModel.IsLoadingVisibility, Mode=OneWay}"
                         Margin="0,10,0,0"/>
        </StackPanel>

        <!-- Безопасный вывод карточек через ItemsControl -->
        <ItemsControl Grid.Row="1" ItemsSource="{x:Bind ViewModel.QuickActions, Mode=OneWay}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:QuickActionViewModel">
                    <!-- 
                         Здесь мы задаем Foreground="{ThemeResource Porto.Text.Default}" на самом корне карточки.
                         Благодаря этому внутренние элементы (FontIcon и TextBlock) унаследуют этот цвет.
                         Когда сработает PointerOverForegroundCustom, контрол CardButton поменяет свой Foreground,
                         и внутренние элементы автоматически перекрасятся вместе с ним.
                    -->
                    <controls:CardButton Width="280" Height="160" Margin="0,0,16,16"
                                         Command="{x:Bind NavigateCommand}"
                                         Background="{ThemeResource Porto.Element.Default}"
                                         BorderBrush="{ThemeResource Porto.Border.Default}"
                                         Foreground="{ThemeResource Porto.Text.Default}"
                                         BorderThickness="1"
                                         CornerRadius="12"
                                         PointerOverBackgroundCustom="{ThemeResource Porto.Element.Hover}"
                                         PointerOverBorderBrushCustom="{ThemeResource Porto.Border.Hover}"
                                         PointerOverForegroundCustom="{ThemeResource Porto.Text.Hover}"
                                         Style="{StaticResource DefaultCardButtonStyle}">
                        <Grid Padding="24">
                            <StackPanel Spacing="12" VerticalAlignment="Center">
                                <!-- Убрали локальный Foreground, чтобы работал Hover -->
                                <FontIcon Glyph="{x:Bind Icon}" FontSize="32" />
                                <StackPanel Spacing="4">
                                    <!-- Убрали локальный Foreground, чтобы работал Hover -->
                                    <TextBlock Text="{x:Bind Title}" 
                                               FontWeight="Bold" FontSize="18" />
                                    <!-- Убрали локальный Foreground, чтобы работал Hover -->
                                    <TextBlock Text="{x:Bind Description}" 
                                               FontSize="13" 
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </controls:CardButton>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>