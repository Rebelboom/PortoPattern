<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PortoPattern.Controls.HighlightTextBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- 
        Используем x:Bind trali для высокой производительности.
        Привязка идет напрямую к Dependency Properties в code-behind.
        -->
        <TextBlock x:Name="PART_TextBlock" 
                   TextWrapping="{x:Bind TextWrapping, Mode=OneWay}"
                   FontSize="{x:Bind FontSize, Mode=OneWay}"
                   Foreground="{ThemeResource Porto.Text.Default}"/>
    </Grid>
</UserControl>