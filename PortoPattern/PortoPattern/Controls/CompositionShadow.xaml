<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PortoPattern.Controls.CompositionShadow"
    x:Name="RootUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <!-- Элемент-контейнер для визуального слоя тени -->
        <Border x:Name="ShadowElement" IsHitTestVisible="False" />

        <!-- Основной контент контрола -->
        <ContentPresenter x:Name="ContentRoot" 
                          Content="{Binding CastingElement, ElementName=RootUserControl}" />
    </Grid>
</UserControl>