<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PortoPattern.Controls.FolderCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:PortoPattern.Controls"
    mc:Ignorable="d">

    <Border
        x:Name="CardBorder"
        Padding="16"
        Margin="4,8"
        CornerRadius="8"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        PointerEntered="OnPointerEntered"
        PointerExited="OnPointerExited">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="6">
                <TextBlock 
                    Text="{x:Bind ViewModel.FolderName, Mode=OneWay}" 
                    FontWeight="Bold" 
                    FontSize="16"/>

                <TextBlock 
                    Text="{x:Bind ViewModel.FileListDisplay, Mode=OneWay}" 
                    FontSize="13" 
                    Opacity="0.8" 
                    TextWrapping="Wrap"/>

                <ToolTipService.ToolTip>
                    <ToolTip Content="{x:Bind ViewModel.FullPath, Mode=OneWay}"/>
                </ToolTipService.ToolTip>
            </StackPanel>

            <StackPanel 
                x:Name="Overlay" 
                Grid.Column="1" 
                Orientation="Horizontal" 
                VerticalAlignment="Top" 
                Opacity="0" 
                IsHitTestVisible="False">

                <Button 
                    Content="Открыть папку" 
                    Command="{x:Bind ViewModel.OpenFolderCommand}"
                    Style="{ThemeResource DefaultButtonStyle}"
                    VerticalAlignment="Top"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>