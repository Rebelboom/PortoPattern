<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PortoPattern.Controls.TopToolBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Height="100" Padding="24,0">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ЦЕНТРАЛЬНЫЙ БЛОК -->
        <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="4">

            <!-- ЗАГОЛОВОК -->
            <TextBlock x:Name="PageTitle"
                       HorizontalAlignment="Center"
                       Style="{ThemeResource TitleTextBlockStyle}"
                       Foreground="{StaticResource App.HeaderText}"/>

            <!-- ПОДЗАГОЛОВОК -->
            <TextBlock x:Name="PageSubtitle"
                       HorizontalAlignment="Center"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Opacity="0.6"
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- ПОИСК -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Spacing="12">

            <!-- Привязываем текст поиска к DependencyProperty нашего контрола (TopToolBar) -->
            <AutoSuggestBox
                x:Name="SearchBox"
                PlaceholderText="Поиск..."
                QueryIcon="Find"
                Width="300"
                Text="{x:Bind SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <!-- НИЖНЯЯ ЛИНИЯ -->
        <Border Height="1"
                Background="{StaticResource App.TextSecondary}"
                Opacity="0.1"
                VerticalAlignment="Bottom"
                Grid.ColumnSpan="3"/>
    </Grid>
</UserControl>