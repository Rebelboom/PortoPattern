<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="PortoPattern.Dialogs.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:root="using:PortoPattern"
    BorderBrush="{StaticResource BorderBrush}"
    BorderThickness="1"
    CloseButtonText=""
    CornerRadius="5"
    DefaultButton="Primary"
    PrimaryButtonText="OK"
    SecondaryButtonText=""
    mc:Ignorable="d">

    <ContentDialog.PrimaryButtonStyle>
        <Style TargetType="Button">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.PrimaryButtonStyle>
    <ContentDialog.SecondaryButtonStyle>
        <Style TargetType="Button">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.SecondaryButtonStyle>
    <ContentDialog.CloseButtonStyle>
        <Style TargetType="Button">
            <Setter Property="CornerRadius" Value="4" />
        </Style>
    </ContentDialog.CloseButtonStyle>

    <ContentDialog.Title>
        <Grid
            x:Name="cdGrid"
            MinWidth="500"
            HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel
                x:Name="cdStack"
                Grid.Column="0"
                Margin="0,4,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Orientation="Horizontal"
                Spacing="12">
                <TextBlock
                    FontSize="{StaticResource FontSizeHuge}"
                    Foreground="{StaticResource SecondaryBrush}"
                    Text="About&#x0020;" />
                <TextBlock
                    x:Name="tbTitle"
                    FontSize="{StaticResource FontSizeHuge}"
                    Foreground="{StaticResource SecondaryBrush}"
                    Text="{x:Bind root:AppConfig.AppName}" />
            </StackPanel>
            <Image
                x:Name="imgLevel"
                Grid.Column="1"
                Height="50"
                Margin="8"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Source="ms-appx:///Assets/Exclamation4.png" />
        </Grid>
    </ContentDialog.Title>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="20,10,20,5"
            FontSize="{StaticResource FontSizeMedium}"
            Foreground="{StaticResource PrimaryBrush}"
            Text="{x:Bind root:AppConfig.Author}"
            TextWrapping="Wrap" />

        <TextBlock
            Grid.Row="1"
            Margin="20,5,20,5"
            FontSize="{StaticResource FontSizeMedium}"
            Foreground="{StaticResource PrimaryBrush}"
            Text="{x:Bind root:AppConfig.Description}"
            TextWrapping="Wrap" />

        <TextBlock
            Grid.Row="2"
            Margin="20,5,20,5"
            FontSize="{StaticResource FontSizeMedium}"
            Foreground="{StaticResource PrimaryBrush}"
            Text="{x:Bind root:AppConfig.EnvironmentNote}"
            TextWrapping="Wrap" />

        <StackPanel
            Grid.Row="3"
            Margin="20,5,20,5"
            Orientation="Vertical"
            Spacing="4">
            <TextBlock
                FontSize="{StaticResource FontSizeMedium}"
                Foreground="{StaticResource SecondaryBrush}"
                Text="Architecture &amp; Contacts:" />
            <ScrollViewer Height="40">
                <TextBlock
                    FontSize="{StaticResource FontSizeMedium}"
                    Foreground="DarkBlue"
                    Text="{x:Bind root:AppConfig.ContactInfo}" />
            </ScrollViewer>
        </StackPanel>

        <StackPanel
            Grid.Row="4"
            Margin="20,20,20,5"
            Orientation="Horizontal"
            Spacing="4">
            <Image
                x:Name="imgSpinner"
                Width="50"
                Height="50"
                Margin="0,1,8,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Opacity="0.9"
                Source="ms-appx:///Assets/Spinner3.png"
                Visibility="Visible">
                <Image.Resources>
                    <Storyboard
                        x:Name="StoryboardSpin"
                        AutoReverse="False"
                        RepeatBehavior="Forever">
                        <DoubleAnimation
                            x:Name="dblAnimation"
                            Storyboard.TargetName="spinnerTransform"
                            Storyboard.TargetProperty="Angle"
                            From="0"
                            To="360"
                            Duration="0:00:01.5" />
                    </Storyboard>
                </Image.Resources>
                <Image.RenderTransform>
                    <RotateTransform x:Name="spinnerTransform" CenterX="25" CenterY="25" />
                </Image.RenderTransform>
            </Image>

            <TextBlock
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeMedium}"
                Foreground="{StaticResource SecondaryBrush}"
                Text="Application version: "
                TextWrapping="NoWrap" />
            <TextBlock
                VerticalAlignment="Center"
                FontSize="{StaticResource FontSizeMedium}"
                Foreground="{StaticResource SecondaryBrush}"
                Text="{x:Bind root:AppConfig.AppVersion}"
                TextWrapping="NoWrap" />
            <TextBlock
                VerticalAlignment="Center"
                Margin="5,0,0,0"
                FontSize="{StaticResource FontSizeMedium}"
                Foreground="DarkBlue"
                Text="{x:Bind root:AppConfig.Architecture}"
                TextWrapping="NoWrap" />
        </StackPanel>
    </Grid>
</ContentDialog>